{"ast":null,"code":"export default {\n  computed: {\n    totalPage() {\n      this.$store.commit('countPage');\n      return this.$store.state.totalPage;\n    },\n    currentPage() {\n      return this.$store.state.pageIndex + 1;\n    },\n    pageIndex() {\n      return this.$store.state.pageIndex;\n    }\n  },\n  methods: {\n    switchPage(calc) {\n      this.$store.commit('switchPage', calc);\n    },\n    goSelectAarea() {\n      this.$emit('goSelectAarea');\n    }\n  },\n  watch: {}\n};","map":{"version":3,"mappings":"AAmCA,eAAe;EAEbA,QAAQ,EAAE;IACRC,SAAS,GAAG;MACV,IAAI,CAACC,MAAM,CAACC,MAAM,CAAC,WAAW,CAAC;MAC/B,OAAO,IAAI,CAACD,MAAM,CAACE,KAAK,CAACH,SAAS;IACpC,CAAC;IACDI,WAAW,GAAG;MACZ,OAAO,IAAI,CAACH,MAAM,CAACE,KAAK,CAACE,SAAQ,GAAI,CAAC;IACxC,CAAC;IACDA,SAAS,GAAG;MACV,OAAO,IAAI,CAACJ,MAAM,CAACE,KAAK,CAACE,SAAS;IACpC;EACF,CAAC;EACDC,OAAO,EAAE;IACPC,UAAU,CAACC,IAAI,EAAE;MACf,IAAI,CAACP,MAAM,CAACC,MAAM,CAAC,YAAY,EAAEM,IAAI,CAAC;IACxC,CAAC;IACDC,aAAa,GAAG;MACd,IAAI,CAACC,KAAK,CAAC,eAAe,CAAC;IAC7B;EACF,CAAC;EACDC,KAAK,EAAE,CACP;AAEF,CAAC","names":["computed","totalPage","$store","commit","state","currentPage","pageIndex","methods","switchPage","calc","goSelectAarea","$emit","watch"],"sourceRoot":"","sources":["S:\\myProject\\meowmeow\\src\\components\\PaginationView.vue"],"sourcesContent":["<template>\n  <!-- ------ 桌機 ----------->\n  <!-- <div class=\"mb-5\">\n    <nav aria-label=\"Page navigation example\">\n      <ul class=\"pagination justify-content-center\">\n        <li class=\"page-item\"><a class=\"page-link\" href=\"#\">〈</a></li>\n        <li class=\"page-item\" v-for=\"(p,index) in totalPage\" :key=\"index\">\n          <a class=\"page-link\" href=\"#\">{{ p }}</a>\n        </li>\n        <li class=\"page-item\"><a class=\"page-link\" href=\"#\">〉</a></li>\n      </ul>\n    </nav>\n  </div> -->\n  <!-- ------ 行動裝置 ----------->\n  <div class=\"mb-5\">\n    <nav aria-label=\"Page navigation example\">\n      <ul class=\"pagination justify-content-center\">\n        <li class=\"page-item\" :class=\"{disabled: pageIndex === 0}\">\n          <a class=\"page-link\" href=\"#\"\n          @click.prevent=\"switchPage('previous');goSelectAarea()\">上一頁</a>\n        </li>\n        <li class=\"page-item disabled\">\n          <a class=\"page-link\" href=\"#\">{{ currentPage }} / {{ totalPage }}</a>\n        </li>\n        <li class=\"page-item\" :class=\"{disabled: pageIndex + 1 === totalPage}\">\n          <a class=\"page-link\" href=\"#\"\n          @click.prevent=\"switchPage('next');goSelectAarea()\">下一頁</a>\n        </li>\n      </ul>\n    </nav>\n  </div>\n   <!-- ---------------------------------------- -->\n</template>\n\n<script>\nexport default {\n\n  computed: {\n    totalPage() {\n      this.$store.commit('countPage');\n      return this.$store.state.totalPage;\n    },\n    currentPage() {\n      return this.$store.state.pageIndex + 1;\n    },\n    pageIndex() {\n      return this.$store.state.pageIndex;\n    },\n  },\n  methods: {\n    switchPage(calc) {\n      this.$store.commit('switchPage', calc);\n    },\n    goSelectAarea() {\n      this.$emit('goSelectAarea');\n    },\n  },\n  watch: {\n  },\n\n};\n</script>\n\n<style lang=\"scss\" scoped>\n\n</style>\n"]},"metadata":{},"sourceType":"module"}