{"ast":null,"code":"import { computed } from 'vue';\nimport { useStore } from 'vuex';\nexport default {\n  setup(_, {\n    emit\n  }) {\n    const store = useStore();\n    const totalPage = computed(() => {\n      store.commit('countPage');\n      return store.state.totalPage;\n    });\n    const currentPage = computed(() => store.state.pageIndex + 1);\n    const pageIndex = computed(() => store.state.pageIndex);\n    function switchPage(calc) {\n      store.commit('switchPage', calc);\n    }\n    function goSelectAarea() {\n      emit('goSelectAarea');\n    }\n    return {\n      totalPage,\n      currentPage,\n      pageIndex,\n      switchPage,\n      goSelectAarea\n    };\n  }\n};","map":{"version":3,"mappings":"AAsBA,SAASA,QAAO,QAAS,KAAK;AAC9B,SAASC,QAAO,QAAS,MAAM;AAE/B,eAAe;EACbC,KAAK,CAACC,CAAC,EAAE;IAAEC;EAAK,CAAC,EAAE;IACjB,MAAMC,KAAI,GAAIJ,QAAQ,EAAE;IAExB,MAAMK,SAAQ,GAAIN,QAAQ,CAAC,MAAM;MAC/BK,KAAK,CAACE,MAAM,CAAC,WAAW,CAAC;MACzB,OAAOF,KAAK,CAACG,KAAK,CAACF,SAAS;IAC9B,CAAC,CAAC;IACF,MAAMG,WAAU,GAAIT,QAAQ,CAAC,MAAMK,KAAK,CAACG,KAAK,CAACE,SAAQ,GAAI,CAAC,CAAC;IAC7D,MAAMA,SAAQ,GAAIV,QAAQ,CAAC,MAAMK,KAAK,CAACG,KAAK,CAACE,SAAS,CAAC;IAEvD,SAASC,UAAU,CAACC,IAAI,EAAE;MACxBP,KAAK,CAACE,MAAM,CAAC,YAAY,EAAEK,IAAI,CAAC;IAClC;IACA,SAASC,aAAa,GAAG;MACvBT,IAAI,CAAC,eAAe,CAAC;IACvB;IAEA,OAAO;MACLE,SAAS;MAAEG,WAAW;MAAEC,SAAS;MAAEC,UAAU;MAAEE;IACjD,CAAC;EACH;AACF,CAAC","names":["computed","useStore","setup","_","emit","store","totalPage","commit","state","currentPage","pageIndex","switchPage","calc","goSelectAarea"],"sourceRoot":"","sources":["S:\\myProject\\meowmeow\\src\\components\\PaginationView.vue"],"sourcesContent":["<template>\n  <div class=\"mb-5\">\n    <nav aria-label=\"Page navigation example\">\n      <ul class=\"pagination justify-content-center\">\n        <li class=\"page-item\" :class=\"{disabled: pageIndex === 0}\">\n          <a class=\"page-link\" href=\"#\"\n          @click.prevent=\"switchPage('previous');goSelectAarea()\">上一頁</a>\n        </li>\n        <li class=\"page-item disabled\">\n          <a class=\"page-link\" href=\"#\">{{ currentPage }} / {{ totalPage }}</a>\n        </li>\n        <li class=\"page-item\" :class=\"{disabled: pageIndex + 1 === totalPage}\">\n          <a class=\"page-link\" href=\"#\"\n          @click.prevent=\"switchPage('next');goSelectAarea()\">下一頁</a>\n        </li>\n      </ul>\n    </nav>\n  </div>\n  <!-- ---------------------------------------- -->\n</template>\n\n<script>\nimport { computed } from 'vue';\nimport { useStore } from 'vuex';\n\nexport default {\n  setup(_, { emit }) {\n    const store = useStore();\n\n    const totalPage = computed(() => {\n      store.commit('countPage');\n      return store.state.totalPage;\n    });\n    const currentPage = computed(() => store.state.pageIndex + 1);\n    const pageIndex = computed(() => store.state.pageIndex);\n\n    function switchPage(calc) {\n      store.commit('switchPage', calc);\n    }\n    function goSelectAarea() {\n      emit('goSelectAarea');\n    }\n\n    return {\n      totalPage, currentPage, pageIndex, switchPage, goSelectAarea,\n    };\n  },\n};\n</script>\n\n<style lang=\"scss\" scoped>\n\n</style>\n"]},"metadata":{},"sourceType":"module"}