lc === 'previous') {\n        page.value -= 1;\n      }\n      store.commit('switchPage', calc);\n      router.push({\n        query: {\n          city: city.value,\n          sex: sex.value,\n          page: page.value,\n        },\n      });\n    }\n\n    function goSelectAarea() {\n      emit('goSelectAarea');\n    }\n\n    watch(route, () => {\n      city.value = route.query.city;\n      sex.value = route.query.sex;\n      page.value = Number(route.query.page);\n      store.commit('nowPage', page.value);\n    });\n\n    return {\n      city, sex, page, totalPage, currentPage, pageIndex, switchPage, goSelectAarea,\n    };\n  },\n\n};\n</script>\n\n<style lang=\"scss\" scoped>\n\n</style>\n"]},"metadata":{},"sourceType":"module"}