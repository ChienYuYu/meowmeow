{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { ref, computed, onMounted, watch } from 'vue';\nimport { useStore } from 'vuex';\nimport { useRoute, useRouter } from 'vue-router';\nexport default {\n  setup(props, {\n    emit\n  }) {\n    const store = useStore();\n    const router = useRouter();\n    const route = useRoute();\n    const city = ref('');\n    const sex = ref('');\n    const page = ref(0);\n    onMounted(() => {\n      city.value = route.query.city;\n      sex.value = route.query.sex;\n      page.value = Number(route.query.page); // 字串轉數字\n      if (Object.keys(route.query).length === 0) {\n        router.push({\n          query: {\n            page: 1\n          }\n        });\n      }\n    });\n    const totalPage = computed(() => {\n      store.commit('countPage');\n      return store.state.totalPage;\n    });\n    const currentPage = computed(() => store.state.pageIndex + 1);\n    const pageIndex = computed(() => store.state.pageIndex);\n    function switchPage(calc) {\n      if (calc === 'next') {\n        page.value += 1;\n      }\n      if (calc === 'previous') {\n        page.value -= 1;\n      }\n      store.commit('switchPage', calc);\n      router.push({\n        query: {\n          city: city.value,\n          sex: sex.value,\n          page: page.value\n        }\n      });\n    }\n    function goSelectAarea() {\n      emit('goSelectAarea');\n    }\n    watch(route, () => {\n      city.value = route.query.city;\n      sex.value = route.query.sex;\n      page.value = Number(route.query.page);\n      store.commit('nowPage', page.value);\n    });\n    return {\n      city,\n      sex,\n      page,\n      totalPage,\n      currentPage,\n      pageIndex,\n      switchPage,\n      goSelectAarea\n    };\n  }\n};","map":{"version":3,"mappings":";AAsBA,SACEA,GAAG,EAAEC,QAAQ,EAAEC,SAAS,EAAEC,KAAK,QAC1B,KAAK;AACZ,SAASC,QAAO,QAAS,MAAM;AAC/B,SAASC,QAAQ,EAAEC,SAAQ,QAAS,YAAY;AAEhD,eAAe;EACbC,KAAK,CAACC,KAAK,EAAE;IAAEC;EAAK,CAAC