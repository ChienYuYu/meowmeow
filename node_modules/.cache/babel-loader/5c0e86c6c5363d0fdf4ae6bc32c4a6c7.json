{"ast":null,"code":"export default {};","map":{"version":3,"mappings":"AAYA,eAAe,CAAC,CAAC","names":[],"sourceRoot":"","sources":["S:\\myProject\\meowmeow\\src\\components\\BannerView.vue"],"sourcesContent":["<template>\n  <div class=\"mb-5\">\n    <div class=\"banner\">\n      <div class=\"title-wrap\">\n        <h2 class=\"title\">給朕一個家</h2>\n        <i class=\"bi bi-caret-down-fill\"></i>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {};\n</script>\n\n<style lang=\"scss\" scoped>\n.banner {\n  background-image: url(../assets/banner01.jpg);\n  height: 100vh;\n  background-size: cover;\n  background-position: center 40%;\n\n  .title-wrap {\n    position: relative; // 動畫\n    animation: downdown 1s infinite;// 動畫\n    height: 100vh;\n    display: flex;\n    flex-direction: column;\n    justify-content:end;\n    align-items: center;\n    padding-bottom: 4rem;\n    .title {\n      background: #e6838380;\n      color: #fff;\n      padding: 1.2rem 2rem;\n      border-radius: 0.5rem;\n      @media (max-width: 430px) {\n        font-size: 28px;\n        padding: 0.8rem 1rem;\n      }\n    }\n    .bi-caret-down-fill {\n      font-size: 70px;\n      line-height: 0;\n      color: #fff;\n      animation: downdown 1s infinite;\n    }\n  }\n}\n@keyframes downdown {\n  0% {\n    bottom: 1%;\n  }\n  50% {\n    bottom: -2%;\n  }\n  100% {\n    bottom: 1%;\n  }\n}\n</style>\n"]},"metadata":{},"sourceType":"module"}