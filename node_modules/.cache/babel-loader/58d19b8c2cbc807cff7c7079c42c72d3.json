{"ast":null,"code":"// https://data.coa.gov.tw/Service/OpenData/TransService.aspx?UnitId=QcbUEzN6E6DL\nexport default {\n  data() {\n    return {\n      lightbox: false,\n      lightboxImg: ''\n    };\n  },\n  computed: {\n    showData() {\n      return this.$store.getters.showData;\n    }\n  },\n  methods: {\n    sexDataTransform(sex) {\n      if (sex === 'M') {\n        return '公';\n      }\n      if (sex === 'F') {\n        return '母';\n      }\n      return '不明';\n    },\n    openAndCloseLightBox(tf, i) {\n      this.lightbox = tf;\n      if (tf === true) {\n        this.lightboxImg = this.showData[i].album_file;\n      }\n    }\n  }\n};","map":{"version":3,"mappings":"AAkDA;AACA,eAAe;EACbA,IAAI,GAAG;IACL,OAAO;MACLC,QAAQ,EAAE,KAAK;MACfC,WAAW,EAAE;IACf,CAAC;EACH,CAAC;EACDC,QAAQ,EAAE;IACRC,QAAQ,GAAG;MACT,OAAO,IAAI,CAACC,MAAM,CAACC,OAAO,CAACF,QAAQ;IACrC;EACF,CAAC;EACDG,OAAO,EAAE;IACPC,gBAAgB,CAACC,GAAG,EAAE;MACpB,IAAIA,GAAE,KAAM,GAAG,EAAE;QACf,OAAO,GAAG;MACZ;MACA,IAAIA,GAAE,KAAM,GAAG,EAAE;QACf,OAAO,GAAG;MACZ;MACA,OAAO,IAAI;IACb,CAAC;IACDC,oBAAoB,CAACC,EAAE,EAAEC,CAAC,EAAE;MAC1B,IAAI,CAACX,QAAO,GAAIU,EAAE;MAClB,IAAIA,EAAC,KAAM,IAAI,EAAE;QACf,IAAI,CAACT,WAAU,GAAI,IAAI,CAACE,QAAQ,CAACQ,CAAC,CAAC,CAACC,UAAU;MAChD;IACF;EACF;AACF,CAAC","names":["data","lightbox","lightboxImg","computed","showData","$store","getters","methods","sexDataTransform","sex","openAndCloseLightBox","tf","i","album_file"],"sourceRoot":"","sources":["S:\\myProject\\meowmeow\\src\\components\\CatList.vue"],"sourcesContent":["<template>\n  <div class=\"cat-list container mb-5\">\n    <div class=\"row mb-5 g-3\">\n      <div class=\"col-12 col-lg-6\" v-for=\"(c, index) in showData\" :key=\"c.animal_id\">\n        <div class=\"card mb-3\" data-aos=\"fade-up\" data-aos-once=\"true\">\n          <div class=\"row g-0\">\n            <div class=\"col-md-4\">\n              <a class=\"text-decoration-none\" href=\"#\"\n              @click.prevent=\"openAndCloseLightBox(true, index)\">\n                <img :src=\"c.album_file\" class=\"img-fluid rounded-start\" alt=\"cat pic\">\n              </a>\n            </div>\n            <div class=\"col-md-8\">\n              <div class=\"card-body\">\n                <p class=\"card-text mb-0 p-1\">\n                  <small class=\"text-muted\">流水編號：{{ c.animal_id }}</small>\n                </p>\n                <p class=\"card-text mb-0 p-1\">\n                  <small class=\"text-muted\">區域編號：{{ c.animal_subid }}</small>\n                </p>\n                <h5 class=\"mb-0 p-1\">\n                  {{ c.animal_colour }}貓咪 性別：{{ sexDataTransform(c.animal_sex) }}\n                </h5>\n                <p class=\"card-text mb-0 p-1\">{{ c.shelter_name }}</p>\n                <p class=\"card-text mb-0 p-1\">{{ c.shelter_address }}</p>\n                <p class=\"card-text mb-0 p-1\">\n                  <small class=\"text-muted\">電話：{{ c.shelter_tel }}</small>\n                </p>\n                <p class=\"card-text mb-0 p-1\">\n                  <small class=\"text-muted\">更新日期：{{ c.cDate }}</small>\n                </p>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n    </div>\n\n  </div>\n  <div class=\"lightbox bg-dark bg-opacity-75\" v-if=\"lightbox\">\n    <div class=\"img-btn-wrap\">\n      <img :src=\"lightboxImg\" alt=\"cat pic\">\n      <button class=\"close-btn \" @click=\"openAndCloseLightBox(false)\">close</button>\n    </div>\n  </div>\n</template>\n\n<script>\n\n// https://data.coa.gov.tw/Service/OpenData/TransService.aspx?UnitId=QcbUEzN6E6DL\nexport default {\n  data() {\n    return {\n      lightbox: false,\n      lightboxImg: '',\n    };\n  },\n  computed: {\n    showData() {\n      return this.$store.getters.showData;\n    },\n  },\n  methods: {\n    sexDataTransform(sex) {\n      if (sex === 'M') {\n        return '公';\n      }\n      if (sex === 'F') {\n        return '母';\n      }\n      return '不明';\n    },\n    openAndCloseLightBox(tf, i) {\n      this.lightbox = tf;\n      if (tf === true) {\n        this.lightboxImg = this.showData[i].album_file;\n      }\n    },\n  },\n};\n</script>\n\n<style lang=\"scss\" scoped>\n.card {\n  height: 280px;\n  overflow: hidden;\n\n  @media (max-width: 830px) {\n    height: auto;\n  }\n\n  img {\n    min-width: 100%;\n    height: 280px;\n    object-fit: cover;\n    position: relative;\n  }\n\n  img:before {\n    content: '喵喵照片無法載入，可能是收容所無提供照片';\n    display: block;\n    background: #f66;\n    color: #fff;\n    padding: .25rem .25rem;\n    font-size: 14px;\n    text-align: center;\n  }\n\n  // img:after{\n  //   content:'(=ↀωↀ=)';\n  //   display: block;\n  //   position: absolute;\n  //   top: 28px;\n  //   left: 0;\n  //   padding: 1rem;\n  //   width: 100%;\n  //   background: #333;\n  //   color: #fff;\n  //   text-align: center;\n  // }\n}\n\n.lightbox {\n  position: fixed;\n  top: 0;\n  bottom: 0;\n  right: 0;\n  left: 0;\n  z-index: 99;\n  display: flex;\n  justify-content: center;\n  align-items: center;\n\n  .img-btn-wrap {\n    max-width: 95%;\n    display: flex;\n    flex-direction: column;\n\n    img {\n      width: 100%;\n      border: 4px solid #fff;\n\n      @media (min-width: 830px) {\n        width: 30vw;\n      }\n    }\n\n    .close-btn {\n      background: #fff;\n      border: none;\n      padding: .5rem 0;\n\n      &:hover {\n        background: #ddd;\n        color: #fff;\n      }\n    }\n  }\n}\n</style>\n"]},"metadata":{},"sourceType":"module"}