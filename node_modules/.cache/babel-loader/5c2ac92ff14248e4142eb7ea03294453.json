{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { ref, computed, $route, $router } from 'vue';\nimport { useStore } from 'vuex';\nexport default {\n  setup() {\n    const store = useStore();\n    const city = ref(['基隆市', '臺北市', '新北市', '桃園市', '新竹市', '新竹縣', '苗栗縣', '臺中市', '彰化縣', '南投縣', '雲林縣', '嘉義市', '嘉義縣', '臺南市', '高雄市', '屏東縣', '臺東縣', '花蓮縣', '宜蘭縣', '澎湖縣', '金門縣', '連江縣']);\n    const myCity = ref('');\n    const sex = ref('');\n    if (Object.keys($route.query).length === 0) {\n      myCity.value = store.state.cityAndSex.city;\n      sex.value = store.state.cityAndSex.sex;\n    } else {\n      // 假如query{}不為空從網址取得city&sex\n      myCity.value = $route.query.city;\n      sex.value = $route.query.sex;\n      store.commit('filterCitySex', {\n        city: myCity.value,\n        sex: sex.value\n      });\n    }\n    const totalPage = computed(() => store.state.totalPage);\n    const filterDataNum = computed(() => store.getters.filterShow.length);\n    const page = computed(() => $route.query.page);\n    function routeUpdate() {\n      $router.push({\n        query: {\n          city: myCity.value,\n          sex: sex.value,\n          page: 1\n        }\n      });\n    }\n    function filterCitySex() {\n      store.commit('filterCitySex', {\n        city: myCity.value,\n        sex: sex.value\n      });\n      routeUpdate();\n    }\n    function reset() {\n      sex.value = '請選擇性別';\n      myCity.value = '請選擇縣市';\n      store.commit('filterCitySex', {\n        city: myCity.value,\n        sex: sex.value\n      });\n      $router.push({\n        query: {\n          page: 1\n        }\n      });\n    }\n    return {\n      city,\n      myCity,\n      sex,\n      totalPage,\n      filterDataNum,\n      page,\n      routeUpdate,\n      filterCitySex,\n      reset\n    };\n  },\n  methods: {},\n  watch: {\n    $route() {\n      if (this.myCity !== '請選擇縣市' || this.sex !== '請選擇性別') {\n        this.myCity = this.$route.query.city;\n        this.sex = this.$route.query.sex;\n      }\n    }\n  }\n};","map":{"version":3,"mappings":";AA4CA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,MAAM,EAAEC,OAAM,QAAS,KAAK;AACpD,SAASC,QAAO,QAAS,MAAM;AAE/B,eAAe;EACbC,KAAK,GAAG;IACN,MAAMC,KAAI,GAAIF,QAAQ,EAAE;IACxB,MAAMG,IAAG,GAAIP,GAAG,CAAC,CAAC,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,CAAC,CAAC;IAC5K,MAAMQ,MAAK,GAAIR,GAAG,CAAC,EAAE,CAAC;IACtB,MAAMS,GAAE,GAAIT,GAAG,CAAC,EAAE,CAAC;IAEnB,IAAIU,MAAM,CAACC,IAAI,CAACT,MAAM,CAACU,KAAK,CAAC,CAACC,MAAK,KAAM,CAAC,EAAE;MAC1CL,MAAM,CAACM,KAAI,GAAIR,KAAK,CAACS,KAAK,CAACC,UAAU,CAACT,IAAI;MAC1CE,GAAG,CAACK,KAAI,GAAIR,KAAK,CAACS,KAAK,CAACC,UAAU,CAACP,GAAG;IACxC,OAAO;MACL;MACAD,MAAM,CAACM,KAAI,GAAIZ,MAAM,CAACU,KAAK,CAACL,IAAI;MAChCE,GAAG,CAACK,KAAI,GAAIZ,MAAM,CAACU,KAAK,CAACH,GAAG;MAC5BH,KAAK,CAACW,MAAM,CAAC,eAAe,EAAE;QAAEV,IAAI,EAAEC,MAAM,CAACM,KAAK;QAAEL,GAAG,EAAEA,GAAG,CAACK;MAAM,CAAC,CAAC;IACvE;IAEA,MAAMI,SAAQ,GAAIjB,QAAQ,CAAC,MAAMK,KAAK,CAACS,KAAK,CAACG,SAAS,CAAC;IACvD,MAAMC,aAAY,GAAIlB,QAAQ,CAAC,MAAMK,KAAK,CAACc,OAAO,CAACC,UAAU,CAACR,MAAM,CAAC;IACrE,MAAMS,IAAG,GAAIrB,QAAQ,CAAC,MAAMC,MAAM,CAACU,KAAK,CAACU,IAAI,CAAC;IAE9C,SAASC,WAAW,GAAG;MACrBpB,OAAO,CAACqB,IAAI,CAAC;QACXZ,KAAK,EAAE;UACLL,IAAI,EAAEC,MAAM,CAACM,KAAK;UAClBL,GAAG,EAAEA,GAAG,CAACK,KAAK;UACdQ,IAAI,EAAE;QACR;MACF,CAAC,CAAC;IACJ;IAEA,SAASG,aAAa,GAAG;MACvBnB,KAAK,CAACW,MAAM,CAAC,eAAe,EAAE;QAAEV,IAAI,EAAEC,MAAM,CAACM,KAAK;QAAEL,GAAG,EAAEA,GAAG,CAACK;MAAM,CAAC,CAAC;MACrES,WAAW,EAAE;IACf;IAEA,SAASG,KAAK,GAAG;MACfjB,GAAG,CAACK,KAAI,GAAI,OAAO;MACnBN,MAAM,CAACM,KAAI,GAAI,OAAO;MACtBR,KAAK,CAACW,MAAM,CAAC,eAAe,EAAE;QAAEV,IAAI,EAAEC,MAAM,CAACM,KAAK;QAAEL,GAAG,EAAEA,GAAG,CAACK;MAAM,CAAC,CAAC;MACrEX,OAAO,CAACqB,IAAI,CAAC;QACXZ,KAAK,EAAE;UAAEU,IAAI,EAAE;QAAE;MACnB,CAAC,CAAC;IACJ;IAEA,OAAO;MACLf,IAAI;MACJC,MAAM;MACNC,GAAG;MACHS,SAAS;MACTC,aAAa;MACbG,IAAI;MACJC,WAAW;MACXE,aAAa;MACbC;IACF,CAAC;EACH,CAAC