ick=\"reset\">重設篩選</button>\n  </div>\n  <p class=\"text-center mb-0 pt-3 text-secondary\"\n  data-aos=\"fade-right\"  data-aos-duration=\"1500\"\n  data-aos-once=\"true\" data-aos-delay=\"300\">\n    目前第 {{ page }} 頁\n  </p>\n </div>\n</template>\n\n<script>\nimport { ref, computed, $route, $router } from 'vue';\nimport { useStore } from 'vuex';\n\nexport default {\n  setup() {\n    const store = useStore();\n    const city = ref(['基隆市', '臺北市', '新北市', '桃園市', '新竹市', '新竹縣', '苗栗縣', '臺中市', '彰化縣', '南投縣', '雲林縣', '嘉義市', '嘉義縣', '臺南市', '高雄市', '屏東縣', '臺東縣', '花蓮縣', '宜蘭縣', '澎湖縣', '金門縣', '連江縣']);\n    const myCity = ref('');\n    const sex = ref('');\n\n    if (Object.keys($route.query).length === 0) {\n      myCity.value = store.state.cityAndSex.city;\n      sex.value = store.state.cityAndSex.sex;\n    } else {\n      // 假如query{}不為空從網址取得city&sex\n      myCity.value = $route.query.city;\n      sex.value = $route.query.sex;\n      store.commit('filterCitySex', { city: myCity.value, sex: sex.value });\n    }\n\n    const totalPage = computed(() => store.state.totalPage);\n    const filterDataNum = computed(() => store.getters.filterShow.length);\n    const page = computed(() => $route.query.page);\n\n    function routeUpdate() {\n      $router.push({\n        query: {\n          city: myCity.value,\n          sex: sex.value,\n          page: 1,\n        },\n      });\n    }\n\n    function filterCitySex() {\n      store.commit('filterCitySex', { city: myCity.value, sex: sex.value });\n      routeUpdate();\n    }\n\n    function reset() {\n      sex.value = '請選擇性別';\n      myCity.value = '請選擇縣市';\n      store.commit('filterCitySex', { city: myCity.value, sex: sex.value });\n      $router.push({\n        query: { page: 1 },\n      });\n    }\n\n    return {\n      city,\n      myCity,\n      sex,\n      totalPage,\n      filterDataNum,\n      page,\n      routeUpdate,\n      filterCitySex,\n      reset,\n    };\n  },\n\n  methods: {\n  },\n  watch: {\n    $route() {\n      if (this.myCity !== '請選擇縣市' || this.sex !== '請選擇性別') {\n        this.myCity = this.$route.query.city;\n        this.sex = this.$route.query.sex;\n      }\n    },\n  },\n};\n</script>\n\n<style lang=\"scss\" scoped>\n  .big-text{\n    font-size: 2rem;\n    color: #f55;\n  }\n  .reset-btn{\n    border:1px solid #f55;\n    color: #f55;\n    transition: .2s;\n    &:hover{\n      background: #f55;\n      color: #fff;\n    }\n  }\n</style>\n"]},"metadata":{},"sourceType":"module"}