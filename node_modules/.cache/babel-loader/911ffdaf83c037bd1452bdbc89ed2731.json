{"ast":null,"code":"import { onMounted, ref, computed } from 'vue';\nimport { useStore } from 'vuex';\nimport AOS from 'aos';\nimport NavbarView from '../components/NavbarView.vue';\nimport BannerView from '../components/BannerView.vue';\nimport SelectView from '../components/SelectView.vue';\nimport CatList from '../components/CatList.vue';\nimport PaginationView from '../components/PaginationView.vue';\nimport FooterView from '../components/FooterView.vue';\nexport default {\n  name: 'HomeView',\n  components: {\n    NavbarView,\n    BannerView,\n    SelectView,\n    CatList,\n    PaginationView,\n    FooterView\n  },\n  setup() {\n    const store = useStore();\n    const showBtn = ref(false);\n    onMounted(() => {\n      store.dispatch('getApi');\n      AOS.init();\n    });\n    onMounted(() => {\n      window.addEventListener('scroll', () => {\n        if (window.scrollY > 900) {\n          showBtn.value = true;\n        } else {\n          showBtn.value = false;\n        }\n      });\n    });\n    function goSelectAarea() {\n      const Element = document.getElementById('filterArea');\n      Element.scrollIntoView({\n        behavior: 'smooth'\n      });\n    }\n    const isLoading = computed(() => store.state.isLoading);\n    return {\n      showBtn,\n      isLoading,\n      goSelectAarea\n    };\n  }\n};","map":{"version":3,"mappings":"AA6BA,SAASA,SAAS,EAAEC,GAAG,EAAEC,QAAO,QAAS,KAAK;AAC9C,SAASC,QAAO,QAAS,MAAM;AAC/B,OAAOC,GAAE,MAAO,KAAK;AACrB,OAAOC,UAAS,MAAO,8BAA8B;AACrD,OAAOC,UAAS,MAAO,8BAA8B;AACrD,OAAOC,UAAS,MAAO,8BAA8B;AACrD,OAAOC,OAAM,MAAO,2BAA2B;AAC/C,OAAOC,cAAa,MAAO,kCAAkC;AAC7D,OAAOC,UAAS,MAAO,8BAA8B;AAErD,eAAe;EACbC,IAAI,EAAE,UAAU;EAChBC,UAAU,EAAE;IACVP,UAAU;IACVC,UAAU;IACVC,UAAU;IACVC,OAAO;IACPC,cAAc;IACdC;EACF,CAAC;EACDG,KAAK,GAAG;IACN,MAAMC,KAAI,GAAIX,QAAQ,EAAE;IACxB,MAAMY,OAAM,GAAId,GAAG,CAAC,KAAK,CAAC;IAE1BD,SAAS,CAAC,MAAM;MACdc,KAAK,CAACE,QAAQ,CAAC,QAAQ,CAAC;MACxBZ,GAAG,CAACa,IAAI,EAAE;IACZ,CAAC,CAAC;IAEFjB,SAAS,CAAC,MAAM;MACdkB,MAAM,CAACC,gBAAgB,CAAC,QAAQ,EAAE,MAAM;QACtC,IAAID,MAAM,CAACE,OAAM,GAAI,GAAG,EAAE;UACxBL,OAAO,CAACM,KAAI,GAAI,IAAI;QACtB,OAAO;UACLN,OAAO,CAACM,KAAI,GAAI,KAAK;QACvB;MACF,CAAC,CAAC;IACJ,CAAC,CAAC;IAEF,SAASC,aAAa,GAAG;MACvB,MAAMC,OAAM,GAAIC,QAAQ,CAACC,cAAc,CAAC,YAAY,CAAC;MACrDF,OAAO,CAACG,cAAc,CAAC;QACrBC,QAAQ,EAAE;MACZ,CAAC,CAAC;IACJ;IAEA,MAAMC,SAAQ,GAAI1B,QAAQ,CAAC,MAAMY,KAAK,CAACe,KAAK,CAACD,SAAS,CAAC;IACvD,OAAO;MAAEb,OAAO;MAAEa,SAAS;MAAEN;IAAc,CAAC;EAC9C;AACF,CAAC","names":["onMounted","ref","computed","useStore","AOS","NavbarView","BannerView","SelectView","CatList","PaginationView","FooterView","name","components","setup","store","showBtn","dispatch","init","window","addEventListener","scrollY","value","goSelectAarea","Element","document","getElementById","scrollIntoView","behavior","isLoading","state"],"sourceRoot":"","sources":["S:\\myProject\\meowmeow\\src\\views\\HomeView.vue"],"sourcesContent":["<template>\n  <div class=\"wrapper\">\n    <div class=\"loading\" v-if=\"isLoading\">\n      <div>\n        <div class=\"spinner-grow text-danger\" role=\"status\">\n          <span class=\"visually-hidden\">Loading...</span>\n        </div>\n        <div class=\"spinner-grow text-warning\" role=\"status\">\n          <span class=\"visually-hidden\">Loading...</span>\n        </div>\n        <div class=\"spinner-grow text-info\" role=\"status\">\n          <span class=\"visually-hidden\">Loading...</span>\n        </div>\n        <p class=\"text-dark text-center\">資料載入中...</p>\n      </div>\n    </div>\n    <NavbarView />\n    <BannerView />\n    <SelectView id=\"filterArea\" />\n    <CatList />\n    <PaginationView @goSelectAarea=\"goSelectAarea\" />\n\n    <a href=\"#\" class=\"btn go-top-btn\" @click.prevent=\"goSelectAarea\" v-show=\"showBtn\">▲</a>\n\n    <FooterView />\n  </div>\n</template>\n\n<script>\nimport { onMounted, ref, computed } from 'vue';\nimport { useStore } from 'vuex';\nimport AOS from 'aos';\nimport NavbarView from '../components/NavbarView.vue';\nimport BannerView from '../components/BannerView.vue';\nimport SelectView from '../components/SelectView.vue';\nimport CatList from '../components/CatList.vue';\nimport PaginationView from '../components/PaginationView.vue';\nimport FooterView from '../components/FooterView.vue';\n\nexport default {\n  name: 'HomeView',\n  components: {\n    NavbarView,\n    BannerView,\n    SelectView,\n    CatList,\n    PaginationView,\n    FooterView,\n  },\n  setup() {\n    const store = useStore();\n    const showBtn = ref(false);\n\n    onMounted(() => {\n      store.dispatch('getApi');\n      AOS.init();\n    });\n\n    onMounted(() => {\n      window.addEventListener('scroll', () => {\n        if (window.scrollY > 900) {\n          showBtn.value = true;\n        } else {\n          showBtn.value = false;\n        }\n      });\n    });\n\n    function goSelectAarea() {\n      const Element = document.getElementById('filterArea');\n      Element.scrollIntoView({\n        behavior: 'smooth',\n      });\n    }\n\n    const isLoading = computed(() => store.state.isLoading);\n    return { showBtn, isLoading, goSelectAarea };\n  },\n};\n</script>\n\n<style scoped>\n.loading {\n  width: 100%;\n  height: 100%;\n  position: fixed;\n  top: 50%;\n  left: 50%;\n  z-index: 99;\n  transform: translate(-50%, -50%);\n  background: #ffffff90;\n  backdrop-filter: blur(10px);\n  display: flex;\n  justify-content: center;\n  align-items: center;\n}\n.spinner-grow {\n  border: 3px solid #fff;\n  margin: 0.25rem;\n}\n.go-top-btn {\n  text-decoration: none;\n  position: fixed;\n  bottom: 0;\n  z-index: 20;\n  right: 0;\n  margin: 0 0.5rem 0.5rem 0;\n  background: #fa0;\n  color: #fff;\n}\n</style>\n"]},"metadata":{},"sourceType":"module"}