{"ast":null,"code":"import AOS from 'aos';\nimport NavbarView from '../components/NavbarView.vue';\nimport BannerView from '../components/BannerView.vue';\nimport SelectView from '../components/SelectView.vue';\nimport CatList from '../components/CatList.vue';\nimport PaginationView from '../components/PaginationView.vue';\nimport FooterView from '../components/FooterView.vue';\nexport default {\n  name: 'HomeView',\n  components: {\n    NavbarView,\n    BannerView,\n    SelectView,\n    CatList,\n    PaginationView,\n    FooterView\n  },\n  mounted() {\n    this.$store.dispatch('getApi');\n    AOS.init();\n    window.addEventListener('scroll', () => {\n      if (window.scrollY > 900) {\n        this.$refs.goTopBtn.classList.remove('d-none');\n      } else {\n        this.$refs.goTopBtn.classList.add('d-none');\n      }\n    });\n  },\n  computed: {\n    isLoading() {\n      return this.$store.state.isLoading;\n    }\n  },\n  methods: {\n    goSelectAarea() {\n      const Element = document.getElementById('filterArea');\n      Element.scrollIntoView({\n        behavior: 'smooth'\n      });\n    }\n  },\n  watch: {}\n};","map":{"version":3,"mappings":"AA+BA,OAAOA,GAAE,MAAO,KAAK;AACrB,OAAOC,UAAS,MAAO,8BAA8B;AACrD,OAAOC,UAAS,MAAO,8BAA8B;AACrD,OAAOC,UAAS,MAAO,8BAA8B;AACrD,OAAOC,OAAM,MAAO,2BAA2B;AAC/C,OAAOC,cAAa,MAAO,kCAAkC;AAC7D,OAAOC,UAAS,MAAO,8BAA8B;AAErD,eAAe;EACbC,IAAI,EAAE,UAAU;EAChBC,UAAU,EAAE;IACVP,UAAU;IACVC,UAAU;IACVC,UAAU;IACVC,OAAO;IACPC,cAAc;IACdC;EACF,CAAC;EACDG,OAAO,GAAG;IACR,IAAI,CAACC,MAAM,CAACC,QAAQ,CAAC,QAAQ,CAAC;IAC9BX,GAAG,CAACY,IAAI,EAAE;IAEVC,MAAM,CAACC,gBAAgB,CAAC,QAAQ,EAAE,MAAM;MACtC,IAAID,MAAM,CAACE,OAAM,GAAI,GAAG,EAAE;QACxB,IAAI,CAACC,KAAK,CAACC,QAAQ,CAACC,SAAS,CAACC,MAAM,CAAC,QAAQ,CAAC;MAChD,OAAO;QACL,IAAI,CAACH,KAAK,CAACC,QAAQ,CAACC,SAAS,CAACE,GAAG,CAAC,QAAQ,CAAC;MAC7C;IACF,CAAC,CAAC;EACJ,CAAC;EACDC,QAAQ,EAAE;IACRC,SAAS,GAAG;MACV,OAAO,IAAI,CAACZ,MAAM,CAACa,KAAK,CAACD,SAAS;IACpC;EACF,CAAC;EACDE,OAAO,EAAE;IACPC,aAAa,GAAG;MACd,MAAMC,OAAM,GAAIC,QAAQ,CAACC,cAAc,CAAC,YAAY,CAAC;MACrDF,OAAO,CAACG,cAAc,CAAC;QACrBC,QAAQ,EAAE;MACZ,CAAC,CAAC;IACJ;EACF,CAAC;EACDC,KAAK,EAAE,CACP;AACF,CAAC","names":["AOS","NavbarView","BannerView","SelectView","CatList","PaginationView","FooterView","name","components","mounted","$store","dispatch","init","window","addEventListener","scrollY","$refs","goTopBtn","classList","remove","add","computed","isLoading","state","methods","goSelectAarea","Element","document","getElementById","scrollIntoView","behavior","watch"],"sourceRoot":"","sources":["S:\\myProject\\meowmeow\\src\\views\\HomeView.vue"],"sourcesContent":["<template>\n <div class=\"wrapper\">\n  <div class=\"loading\" v-if=\"isLoading\">\n    <div>\n      <div class=\"spinner-grow text-danger\" role=\"status\">\n        <span class=\"visually-hidden\">Loading...</span>\n      </div>\n      <div class=\"spinner-grow text-warning\" role=\"status\">\n        <span class=\"visually-hidden\">Loading...</span>\n      </div>\n      <div class=\"spinner-grow text-info\" role=\"status\">\n        <span class=\"visually-hidden\">Loading...</span>\n      </div>\n      <p class=\"text-dark text-center\">資料載入中...</p>\n    </div>\n  </div>\n  <NavbarView />\n  <BannerView />\n  <SelectView id=\"filterArea\" />\n  <CatList />\n  <PaginationView @goSelectAarea=\"goSelectAarea\" />\n\n  <a href=\"#\" ref=\"goTopBtn\"\n  class=\"btn go-top-btn d-none\"\n  @click.prevent=\"goSelectAarea\">▲</a>\n\n  <FooterView />\n </div>\n</template>\n\n<script>\nimport AOS from 'aos';\nimport NavbarView from '../components/NavbarView.vue';\nimport BannerView from '../components/BannerView.vue';\nimport SelectView from '../components/SelectView.vue';\nimport CatList from '../components/CatList.vue';\nimport PaginationView from '../components/PaginationView.vue';\nimport FooterView from '../components/FooterView.vue';\n\nexport default {\n  name: 'HomeView',\n  components: {\n    NavbarView,\n    BannerView,\n    SelectView,\n    CatList,\n    PaginationView,\n    FooterView,\n  },\n  mounted() {\n    this.$store.dispatch('getApi');\n    AOS.init();\n\n    window.addEventListener('scroll', () => {\n      if (window.scrollY > 900) {\n        this.$refs.goTopBtn.classList.remove('d-none');\n      } else {\n        this.$refs.goTopBtn.classList.add('d-none');\n      }\n    });\n  },\n  computed: {\n    isLoading() {\n      return this.$store.state.isLoading;\n    },\n  },\n  methods: {\n    goSelectAarea() {\n      const Element = document.getElementById('filterArea');\n      Element.scrollIntoView({\n        behavior: 'smooth',\n      });\n    },\n  },\n  watch: {\n  },\n};\n</script>\n\n<style scoped>\n.loading{\n  width: 100%;\n  height: 100%;\n  position: fixed;\n  top: 50%;\n  left: 50%;\n  z-index: 99;\n  transform: translate(-50%, -50%);\n  background: #ffffff90;\n  backdrop-filter: blur(10px);\n  display: flex;\n  justify-content: center;\n  align-items: center;\n}\n.spinner-grow{\n  border: 3px solid #fff;\n  margin: .25rem;\n}\n.go-top-btn{\n    text-decoration: none;\n    position: fixed;\n    bottom: 0;\n    z-index: 20;\n    right: 0;\n    margin: 0 .5rem .5rem 0 ;\n    background: #fa0;\n    color: #fff;\n  }\n</style>\n"]},"metadata":{},"sourceType":"module"}