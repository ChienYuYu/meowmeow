item\" :class=\"{disabled: page === totalPage}\">\n          <a class=\"page-link\" href=\"#\"\n          @click.prevent=\"switchPage('next');goSelectAarea()\">下一頁</a>\n        </li>\n      </ul>\n    </nav>\n  </div>\n   <!-- ---------------------------------------- -->\n</template>\n\n<script>\nexport default {\n  data() {\n    return {\n      city: '',\n      sex: '',\n      page: 0,\n    };\n  },\n  mounted() {\n    this.city = this.$route.query.city;\n    this.sex = this.$route.query.sex;\n    this.page = Number(this.$route.query.page); // 字串轉數字\n    if (Object.keys(this.$route.query).length === 0) {\n      this.$router.push({\n        query: { page: 1 },\n      });\n    }\n  },\n  computed: {\n    totalPage() {\n      this.$store.commit('countPage');\n      return this.$store.state.totalPage;\n    },\n    currentPage() {\n      return this.$store.state.pageIndex + 1;\n    },\n    pageIndex() {\n      return this.$store.state.pageIndex;\n    },\n  },\n  methods: {\n    switchPage(calc) {\n      if (calc === 'next') {\n        this.page += 1;\n      }\n      if (calc === 'previous') {\n        this.page -= 1;\n      }\n      this.$store.commit('switchPage', calc);\n      this.$router.push({\n        query: {\n          city: this.city,\n          sex: this.sex,\n          page: this.page,\n        },\n      });\n    },\n    goSelectAarea() {\n      this.$emit('goSelectAarea');\n    },\n  },\n  watch: {\n    $route() {\n      this.city = this.$route.query.city;\n      this.sex = this.$route.query.sex;\n      this.page = Number(this.$route.query.page);\n      this.$store.commit('nowPage', this.page);\n    },\n  },\n\n};\n</script>\n\n<style lang=\"scss\" scoped>\n\n</style>\n"]},"metadata":{},"sourceType":"module"}