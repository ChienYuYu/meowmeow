{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nexport default {\n  data() {\n    return {\n      city: '',\n      sex: '',\n      page: 0\n    };\n  },\n  mounted() {\n    this.city = this.$route.query.city;\n    this.sex = this.$route.query.sex;\n    this.page = Number(this.$route.query.page); // 字串轉數字\n    if (Object.keys(this.$route.query).length === 0) {\n      this.$router.push({\n        query: {\n          page: 1\n        }\n      });\n    }\n  },\n  computed: {\n    totalPage() {\n      this.$store.commit('countPage');\n      return this.$store.state.totalPage;\n    },\n    currentPage() {\n      return this.$store.state.pageIndex + 1;\n    },\n    pageIndex() {\n      return this.$store.state.pageIndex;\n    }\n  },\n  methods: {\n    switchPage(calc) {\n      if (calc === 'next') {\n        this.page += 1;\n      }\n      if (calc === 'previous') {\n        this.page -= 1;\n      }\n      this.$store.commit('switchPage', calc);\n      this.$router.push({\n        query: {\n          city: this.city,\n          sex: this.sex,\n          page: this.page\n        }\n      });\n    },\n    goSelectAarea() {\n      this.$emit('goSelectAarea');\n    }\n  },\n  watch: {\n    $route() {\n      this.city = this.$route.query.city;\n      this.sex = this.$route.query.sex;\n      this.page = Number(this.$route.query.page);\n      this.$store.commit('nowPage', this.page);\n    }\n  }\n};","map":{"version":3,"mappings":";AAsBA,eAAe;EACbA,IAAI,GAAG;IACL,OAAO;MACLC,IAAI,EAAE,EAAE;MACRC,GAAG,EAAE,EAAE;MACPC,IAAI,EAAE;IACR,CAAC;EACH,CAAC;EACDC,OAAO,GAAG;IACR,IAAI,CAACH,IAAG,GAAI,IAAI,CAACI,MAAM,CAACC,KAAK,CAACL,IAAI;IAClC,IAAI,CAACC,GAAE,GAAI,IAAI,CAACG,MAAM,CAACC,KAAK,CAACJ,GAAG;IAChC,IAAI,CAACC,IAAG,GAAII,MAAM,CAAC,IAAI,CAACF,MAAM,CAACC,KAAK,CAACH,IAAI,CAAC,EAAE;IAC5C,IAAIK,MAAM,CAACC,IAAI,CAAC,IAAI,CAACJ,MAAM,CAACC,KAAK,CAAC,CAACI,MAAK,KAAM,CAAC,EAAE;MAC/C,IAAI,CAACC,OAAO,CAACC,IAAI,CAAC;QAChBN,KAAK,EAAE;UAAEH,IAAI,EAAE;QAAE;MACnB,CAAC,CAAC;IACJ;EACF,