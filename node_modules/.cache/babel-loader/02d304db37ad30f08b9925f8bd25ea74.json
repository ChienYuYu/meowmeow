{"ast":null,"code":"import { onMounted, computed, ref } from 'vue';\nimport { useStore } from 'vuex';\nimport AOS from 'aos';\nimport NavbarView from '../components/NavbarView.vue';\nimport BannerView from '../components/BannerView.vue';\nimport SelectView from '../components/SelectView.vue';\nimport CatList from '../components/CatList.vue';\nimport PaginationView from '../components/PaginationView.vue';\nimport FooterView from '../components/FooterView.vue';\nexport default {\n  name: 'HomeView',\n  components: {\n    NavbarView,\n    BannerView,\n    SelectView,\n    CatList,\n    PaginationView,\n    FooterView\n  },\n  setup() {\n    const store = useStore();\n    const goTopBtn = ref(null);\n    onMounted(() => {\n      store.dispatch('getApi');\n      AOS.init();\n      window.addEventListener('scroll', () => {\n        if (window.scrollY > 900) {\n          goTopBtn.value.classList.remove('d-none');\n        } else {\n          goTopBtn.value.classList.add('d-none');\n        }\n      });\n    });\n    const isLoading = computed(() => store.state.isLoading);\n    const goSelectAarea = () => {\n      const Element = document.getElementById('filterArea');\n      Element.scrollIntoView({\n        behavior: 'smooth'\n      });\n    };\n    return {\n      isLoading,\n      goTopBtn,\n      goSelectAarea\n    };\n  }\n  // mounted() {\n  //   this.$store.dispatch('getApi');\n  //   AOS.init();\n\n  //   window.addEventListener('scroll', () => {\n  //     if (window.scrollY > 900) {\n  //       this.$refs.goTopBtn.classList.remove('d-none');\n  //     } else {\n  //       this.$refs.goTopBtn.classList.add('d-none');\n  //     }\n  //   });\n  // },\n  // computed: {\n  //   isLoading() {\n  //     return this.$store.state.isLoading;\n  //   },\n  // },\n  // methods: {\n  //   goSelectAarea() {\n  //     const Element = document.getElementById('filterArea');\n  //     Element.scrollIntoView({\n  //       behavior: 'smooth',\n  //     });\n  //   },\n  // },\n};","m