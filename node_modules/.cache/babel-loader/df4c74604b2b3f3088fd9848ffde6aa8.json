{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { ref, computed, watch } from 'vue';\nimport { useStore } from 'vuex';\nimport { useRouter, useRoute } from 'vue-router';\nexport default {\n  setup() {\n    const store = useStore();\n    const router = useRouter();\n    const route = useRoute();\n    const city = ref(['基隆市', '臺北市', '新北市', '桃園市', '新竹市', '新竹縣', '苗栗縣', '臺中市', '彰化縣', '南投縣', '雲林縣', '嘉義市', '嘉義縣', '臺南市', '高雄市', '屏東縣', '臺東縣', '花蓮縣', '宜蘭縣', '澎湖縣', '金門縣', '連江縣']);\n    const myCity = ref('');\n    const sex = ref('');\n\n    // function init() {\n    //   if (Object.keys(route.query).length === 0) {\n    //     myCity.value = store.state.cityAndSex.city;\n    //     sex.value = store.state.cityAndSex.sex;\n    //   } else {\n    //   // 假如query{}不為空從網址取得city&sex\n    //     myCity.value = route.query.city;\n    //     sex.value = route.query.sex;\n    //     store.commit('filterCitySex', { city: myCity.value, sex: sex.value });\n    //   }\n    // }\n    // init();\n\n    if (Object.keys($route.query).length === 0) {\n      myCity.value = store.state.cityAndSex.city;\n      sex.value = store.state.cityAndSex.sex;\n    } else {\n      // 假如query{}不為空從網址取得city&sex\n      myCity.value = $route.query.city;\n      sex.value = $route.query.sex;\n      store.commit('filterCitySex', {\n        city: myCity.value,\n        sex: sex.value\n      });\n    }\n    const totalPage = computed(() => store.state.totalPage);\n    const filterDataNum = computed(() => store.getters.filterShow.length);\n    const page = computed(() => route.query.page);\n    function routeUpdate() {\n      router.push({\n        query: {\n          city: myCity.value,\n          sex: sex.value,\n          page: 1\n        }\n      });\n    }\n    function filterCitySex() {\n      store.commit('filterCitySex', {\n        city: myCity.value,\n        sex: sex.value\n      });\n      routeUpdate();\n    }\n    function reset() {\n      sex.value = '請選擇性別';\n      myCity.value = '請選擇縣市';\n      store.commit('filterCitySex', {\n        city: myCity.value,\n        sex: sex.value\n      });\n      router.push({\n        query: {\n          page: 1\n        }\n      });\n    }\n    watch(route, () => {\n      if (myCity.value !== '請選擇縣市' || sex.value !== '請選擇性別') {\n        myCity.value = route.query.city;\n        sex.value = route.query.sex;\n      }\n    });\n    return {\n      city,\n      myCity,\n      sex,\n      totalPage,\n      filterDataNum,\n      page,\n      routeUpdate,\n      filterCitySex,\n      reset,\n      init\n    };\n  }\n};","map":{"version":3,"mappings":";AA4CA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,KAAI,QAAS,KAAK;AAC1C,SAASC,QAAO,QAAS,MAAM;AAC/B,SAASC,SAAS,EAAEC,QAAO,QAAS,YAAY;AAEhD,eAAe;EACbC,KAAK,GAAG;IACN,MAAMC,KAAI,GAAIJ,QAAQ,EAAE;IACxB,MAAMK,MAAK,GAAIJ,SAAS,EAAE;IAC1B,MAAMK,KAAI,GAAIJ,QAAQ,EAAE;IACxB,MAAMK,IAAG,GAAIV,GAAG,CAAC,CAAC,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,CAAC,CAAC;IAC5K,MAAMW,MAAK,GAAIX,GAAG,CAAC,EAAE,CAAC;IACtB,MAAMY,GAAE,GAAIZ,GAAG,CAAC,EAAE,CAAC;;IAEnB;IACA;IACA;IACA;IACA;IACA;IACA;IACA;IACA;IACA;IACA;IACA;;IAEA,IAAIa,MAAM,CAACC,IAAI,CAACC,MAAM,CAACC,KAAK,CAAC,CAACC,MAAK,KAAM,CAAC,EAAE;MAC1CN,MAAM,CAACO,KAAI,GAAIX,KAAK,CAACY,KAAK,CAACC,UAAU,CAACV,IAAI;MAC1CE,GAAG,CAACM,KAAI,GAAIX,KAAK,CAACY,KAAK,CAACC,UAAU,CAACR,GAAG;IACxC,OAAO;MACL;MACAD,MAAM,CAACO,KAAI,GAAIH,MAAM,CAACC,KAAK,CAACN,IAAI;MAChCE,GAAG,CAACM,KAAI,GAAIH,MAAM,CAACC,KAAK,CAACJ,GAAG;MAC5BL,KAAK,CAACc,MAAM,CAAC,eAAe,EAAE;QAAEX,IAAI,EAAEC,MAAM,CAACO,KAAK;QAAEN,GAAG,EAAEA,GAAG,CAACM;MAAM,CAAC,CAAC;IACvE;IAEA,MAAMI,SAAQ,GAAIrB,QAAQ,CAAC,MAAMM,KAAK,CAACY,KAAK,CAACG,SAAS,CAAC;IACvD,MAAMC,aAAY,GAAItB,QAAQ,CAAC,MAAMM,KAAK,CAACiB,OAAO,CAACC,UAAU,CAACR,MAAM,CAAC;IACrE,MAAMS,IAAG,GAAIzB,QAAQ,CAAC,MAAMQ,KAAK,CAACO,KAAK,CAACU,IAAI,CAAC;IAE7C,SAASC,WAAW,GAAG;MACrBnB,MAAM,CAACoB,IAAI